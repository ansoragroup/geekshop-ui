{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/enforce-component-rules.sh",
            "timeout": 5,
            "statusMessage": "Checking component rules..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash consilium/hooks/pre-commit.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/block-push-main.sh",
            "timeout": 3,
            "statusMessage": "Checking push target..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-reminder.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/typecheck-after-edit.sh",
            "timeout": 30,
            "statusMessage": "Type checking..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash consilium/hooks/session-start.sh",
            "timeout": 15,
            "statusMessage": "Initializing consilium workspace..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash consilium/hooks/pre-compact.sh",
            "timeout": 10,
            "statusMessage": "Saving state before compaction..."
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash consilium/hooks/post-compact.sh",
            "timeout": 10,
            "statusMessage": "Restoring context..."
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash consilium/hooks/task-completed.sh",
            "timeout": 120,
            "statusMessage": "Running quality gates..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/agent-done-qa-reminder.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash consilium/hooks/teammate-idle.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(/tmp/consilium/**)",
      "Write(src/**)",
      "Write(tests/**)",
      "Write(test/**)",
      "Write(consilium/memory/**)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(tree *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(date *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(npm test*)",
      "Bash(npm run lint*)",
      "Bash(npm run build*)",
      "Bash(npm run type*)",
      "Bash(npx tsc*)",
      "Bash(npx eslint*)",
      "Bash(npx vitest*)",
      "Bash(npx prettier*)",
      "Bash(npx storybook*)",
      "Bash(docker compose*)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(ln *)",
      "Bash(chmod +x *)",
      "Bash(jq *)",
      "Write(.agent/**)",
      "Write(.claude/agents/**)",
      "Bash(python3 *)",
      "Bash(bash scripts/*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(sudo *)",
      "Bash(chmod 777*)",
      "Bash(docker rm*)",
      "Bash(docker stop*)",
      "Bash(docker kill*)"
    ]
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  }
}
